# =============================================================
# Socratica - Environment Variable Template
# Copy this to .env and fill in real values.
# NEVER commit the .env file to version control.
# =============================================================

# --- Application ---
APP_ENV=development          # development | production
APP_PORT=8000
LOG_LEVEL=INFO

# --- Database ---
# SQLite (default for local/edge deployment):
DATABASE_URL=sqlite+aiosqlite:///./socratica.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/socratica

# --- Redis (optional - for Celery task queue in high-load deployment) ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama Local Inference ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VLM_MODEL=llava:13b
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=60

# --- Rate Limiting ---
RATE_LIMIT_OLLAMA=30/minute
RATE_LIMIT_GENERAL=120/minute

# --- GitHub PAT (for CI/CD workflows only, never exposed to app) ---
# GITHUB_PAT=github_pat_...
